rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // Users cannot be deleted via client
    }

    // ── Teams ────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.members.map(m, m.uid)
      );
      allow delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // ── Tasks ────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if false; // Comments are immutable
      }
    }

    // ── Notifications ────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if false;
    }

    // ── Activity Log ─────────────────────────────────────
    match /activityLog/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Logs are immutable
    }

    // ── Sprints ──────────────────────────────────────────
    match /sprints/{sprintId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // ── Standup Digests ──────────────────────────────────
    match /standupDigests/{digestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
